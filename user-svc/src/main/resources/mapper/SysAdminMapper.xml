<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.usersvc.mapper.SysAdminMapper">

    <sql id="Base_Column_List">id, username, password, role_type, status, create_time, update_time</sql>

    <select id="selectById" resultType="org.example.common.entity.SysAdmin">
        SELECT <include refid="Base_Column_List"/>
        FROM `sys_admin`
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultType="org.example.common.entity.SysAdmin">
        SELECT <include refid="Base_Column_List"/>
        FROM `sys_admin`
        WHERE username = #{username}
        LIMIT 1
    </select>

    <select id="selectAll" resultType="org.example.common.entity.SysAdmin">
        SELECT <include refid="Base_Column_List"/>
        FROM `sys_admin`
    </select>

    <insert id="insert" parameterType="org.example.common.entity.SysAdmin" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO `sys_admin` (username, password, role_type, status, create_time, update_time)
        VALUES (#{username}, #{password}, #{roleType}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="updateById" parameterType="org.example.common.entity.SysAdmin">
        UPDATE `sys_admin`
        SET
            username = #{username},
            password = #{password},
            role_type = #{roleType},
            status = #{status},
            create_time = #{createTime},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM `sys_admin`
        WHERE id = #{id}
    </delete>

</mapper>
